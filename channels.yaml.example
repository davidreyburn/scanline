channels:
  - name: "Aleph Monitor"
    number: 1
    type: webpage
    uri: "http://YOUR_SERVER_IP:8081"

  - name: "ASCII Topography"
    number: 2
    type: topo
    palette: "PHOSPHOR"
    speed: "MED"

  - name: "Lo-Fi Radio"
    number: 3
    type: stream
    uri: "https://www.youtube.com/watch?v=jfKfPfyJRdk"

  - name: "Plex — Synthwave Mix"
    number: 4
    type: plex_playlist
    uri: "http://YOUR_PLEX_SERVER_IP:32400"
    playlist_id: "YOUR_PLAYLIST_ID"    # numeric ID from Plex API
    token: "YOUR_PLEX_TOKEN"           # raw token value (not "X-Plex-Token=...")

  - name: "Local Media"
    number: 5
    type: media
    path: "/mnt/media/ambient"
    loop: true

  - name: "WeatherStar 4000"
    number: 6
    type: webpage
    uri: "http://YOUR_WS4KP_SERVER:8090/index.html?latLonQuery=YOUR_ZIP&kiosk=true&settings-wide-checkbox=true&settings-mediaPlaying-boolean=true"

  - name: "Claude Plays Pokemon"
    number: 7
    type: stream
    uri: "https://www.twitch.tv/claudeplayspokemon"

settings:
  default_channel: 2
  resume_last_channel: true
  loading_timeout_s: 10
  audio_device: "alsa/sysdefault:CARD=vc4hdmi"
